# Copy to .env for LOCAL development only. Never commit .env.
# In cloud routines, set these as environment variables ON THE ROUTINE, not in a file.

# Perplexity (narrative research, catalysts, sector calls)
PERPLEXITY_API_KEY=pplx-your-key-here
PERPLEXITY_MODEL=sonar

# Telegram bot (notifications to your phone)
# Create: message @BotFather on Telegram, /newbot, save the token.
# Get chat ID: message your bot, then curl https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=1234567890:ABCDEF...
TELEGRAM_CHAT_ID=123456789

# Screener.in (fundamentals) - optional login for richer data
# On free tier, scraper works without login. With login, some pages are richer.
# Paid plan (₹1,999/yr) unlocks JSON export — SCREENER_SESSION is the Django sessionid cookie.
SCREENER_SESSION=
